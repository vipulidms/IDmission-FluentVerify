# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Database (Supabase PostgreSQL)
# Connect to Supabase via connection pooling with Supavisor (port 6543)
DATABASE_URL="postgres://postgres.xxx:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database (port 5432). Used for migrations.
DIRECT_URL="postgres://postgres.xxx:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# NextAuth.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-secret-here"

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY="your-gemini-api-key-here"
